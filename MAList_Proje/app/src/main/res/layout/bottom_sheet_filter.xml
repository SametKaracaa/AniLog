<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_bg"
    android:paddingBottom="@dimen/padding_lg">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:background="@color/text_tertiary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_md"
        android:layout_marginTop="@dimen/padding_md"
        android:text="@string/filter_genre"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_subtitle"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/padding_md"
        android:layout_marginTop="@dimen/padding_sm" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_md"
        android:layout_marginTop="@dimen/padding_md"
        android:text="@string/filter_sort_by"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_subtitle"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupSort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/padding_md"
        android:layout_marginTop="@dimen/padding_sm"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipSortScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.Chip.Filter"
            android:text="@string/sort_score" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipSortPopularity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.Chip.Filter"
            android:text="@string/sort_popularity" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipSortDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.Chip.Filter"
            android:text="@string/sort_date" />
    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_md"
        android:layout_marginTop="@dimen/padding_md"
        android:text="@string/filter_order"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_subtitle"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupOrder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/padding_md"
        android:layout_marginTop="@dimen/padding_sm"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipOrderDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.Chip.Filter"
            android:text="@string/order_desc" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipOrderAsc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.Chip.Filter"
            android:text="@string/order_asc" />
    </com.google.android.material.chip.ChipGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/padding_md"
        android:paddingHorizontal="@dimen/padding_md">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClear"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/padding_sm"
            android:text="@string/btn_clear"
            app:strokeColor="@color/text_tertiary"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApply"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/padding_sm"
            android:text="@string/btn_apply"
            android:backgroundTint="@color/accent_primary"
            android:textColor="@android:color/white" />
    </LinearLayout>
</LinearLayout>
